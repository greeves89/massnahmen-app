# Generiere einen sicheren Schlüssel mit: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Initial-Admin (wird beim ersten Start angelegt, falls noch kein User existiert)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=changeme
INITIAL_ADMIN_NAME=Admin

# Hinter HTTPS-Reverse-Proxy auf true setzen (Cookie Secure-Flag)
COOKIE_SECURE=false

# Lokaler Host-Port für nginx-Proxy (Standard 8090). Anpassen bei Port-Konflikt.
HOST_PORT=8090
